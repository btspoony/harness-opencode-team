{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "/private/tmp/**": "allow",
      "/tmp/**": "allow",
      "~/.cargo/**": "allow"
    },
    "skill": {
      "*": "allow",
      "experimental-*": "ask"
    },
    "*": "allow"
  },
  "model": "zhipuai-coding-plan/glm-5-turbo",
  "default_agent": "project-manager",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "mcp": {
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "gitnexus": {
      "type": "local",
      "command": [
        "gitnexus",
        "mcp"
      ]
    },
    "web-search-prime": {
      "type": "remote",
      "url": "https://open.bigmodel.cn/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "Bearer {env:Z_AI_API_KEY}"
      }
    },
    "web-reader": {
      "type": "remote",
      "url": "https://open.bigmodel.cn/api/mcp/web_reader/mcp",
      "headers": {
        "Authorization": "Bearer {env:Z_AI_API_KEY}"
      }
    },
    "zread": {
      "type": "remote",
      "url": "https://open.bigmodel.cn/api/mcp/zread/mcp",
      "headers": {
        "Authorization": "Bearer {env:Z_AI_API_KEY}"
      }
    },
    "zai-mcp-server": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@z_ai/mcp-server"
      ],
      "environment": {
        "Z_AI_MODE": "ZHIPU",
        "Z_AI_API_KEY": "{env:Z_AI_API_KEY}"
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    }
  },
  "provider": {
    "zhipuai-coding-plan": {
      "options": {
        "apiKey": "{env:Z_AI_API_KEY}"
      }
    }
  },
  "agent": {
    "project-manager": {
      "mode": "primary",
      "model": "zhipuai-coding-plan/glm-5-turbo"
    },
    "product-manager": {
      "mode": "subagent",
      "model": "bailian-coding-plan/qwen3.5-plus"
    },
    "architect": {
      "mode": "subagent",
      "model": "zhipuai-coding-plan/glm-5-turbo"
    },
    "fullstack-dev": {
      "mode": "subagent",
      "model": "zhipuai-coding-plan/glm-5-turbo"
    },
    "fullstack-dev-2": {
      "mode": "subagent",
      "model": "bailian-coding-plan/glm-5"
    },
    "frontend-dev": {
      "mode": "subagent",
      "model": "bailian-coding-plan/kimi-k2.5"
    },
    "qa-engineer": {
      "mode": "subagent",
      "model": "minimax-cn-coding-plan/MiniMax-M2.7"
    },
    "qc-specialist": {
      "mode": "subagent",
      "model": "bailian-coding-plan/glm-5"
    },
    "qc-specialist-2": {
      "mode": "subagent",
      "model": "bailian-coding-plan/kimi-k2.5"
    },
    "qc-specialist-3": {
      "mode": "subagent",
      "model": "minimax-cn-coding-plan/MiniMax-M2.7"
    },
    "ops-engineer": {
      "mode": "subagent",
      "model": "bailian-coding-plan/kimi-k2.5"
    },
    "market-expert": {
      "mode": "subagent",
      "model": "bailian-coding-plan/qwen3.5-plus"
    },
    "prompt-engineer": {
      "mode": "subagent",
      "model": "minimax-cn-coding-plan/MiniMax-M2.7"
    }
  }
}